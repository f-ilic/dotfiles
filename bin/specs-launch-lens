#!/bin/bash

# Lens launcher script for linux-based firmwares (OS_NEXT and Stinson)
# 
# If no lens name is provided, the script will list all installed lenses and prompt the user to select a lens interactively.
# Note: This script closes system-ui before launching the lens, which means after launching the lens, via the script you will
# not be able to see the system-ui or close the lens from the hand menu. The main intention of this script is for support launching
# lenses from the command line in situations where the system-ui is not available or not working properly.

if [ -z "$APP_SOC"  ]; then
    APP_SOC=`adb devices | grep -e app | awk '{print $1}'`

    if [ -z "$APP_SOC"  ]; then
        echo "Error: No device found"
        exit 1
    fi

    echo "Auto-detected device: $APP_SOC"
else
    echo "Using device: $APP_SOC"
fi

if [ $# -eq 0 ]; then
    # Get list of installed lenses
    LENSES=`adb -s $APP_SOC shell snapos lens list-installed | awk 'NR%2==0' | tail -n +2 | sed '/| *| *|/d' | cut -f 2 -d '|'`

    LENS_ARRAY=()
    while IFS= read -r line; do
        LENS_ARRAY+=("$line")
    done <<< "$LENSES"

    if [ ${#LENS_ARRAY[@]} -eq 0 ]; then
        echo "Error: No lenses found on device"
        exit 1
    fi

    # Display numbered list of lenses
    echo ""
    echo "Available Lenses:"
    echo "================="
    for i in "${!LENS_ARRAY[@]}"; do
        printf "%2d) %s\n" $((i+1)) "${LENS_ARRAY[$i]}"
    done

    # Prompt for selection
    echo ""
    read -p "Select a lens number (1-${#LENS_ARRAY[@]}): " selection

    if ! [[ "$selection" =~ ^[0-9]+$ ]] || [ "$selection" -lt 1 ] || [ "$selection" -gt ${#LENS_ARRAY[@]} ]; then
        echo "Error: Invalid selection. Please enter a number between 1 and ${#LENS_ARRAY[@]}"
        exit 1
    fi

    SELECTED_LENS="${LENS_ARRAY[$((selection-1))]}"
else
    SELECTED_LENS="$1"
fi

echo "Turning on display"
adb -s $APP_SOC root
adb -s $APP_SOC shell snap_ar_display_manager_cli display on

echo ""
echo "Stopping system ui"
adb -s $APP_SOC shell snapos lens stop avalon_system_ui > /dev/null 2>&1 # This fails with error messages if system-ui is not running.

echo ""
echo "Launching lens: $SELECTED_LENS"
adb -s $APP_SOC shell snapos lens start "$SELECTED_LENS"
